# ============================================================
# CONFIGURAÇÕES GERAIS
# ============================================================
APP_ENV=development
APP_SECRET_KEY=troque-por-uma-chave-segura-minimo-32-chars
APP_DEBUG=true

# ============================================================
# POSTGRESQL — DATA WAREHOUSE
# Nunca comitar este arquivo com valores reais.
# ============================================================
DW_HOST=localhost
DW_PORT=5432
DW_NAME=financeiro_dw
DW_USER=fpa_user
DW_PASSWORD=troque-por-senha-segura

# URL completa (usada pelo SQLAlchemy e Alembic)
DATABASE_URL=postgresql+psycopg2://fpa_user:troque-por-senha-segura@localhost:5432/financeiro_dw

# ============================================================
# SYSTEM SIA — SOMENTE LEITURA
# Driver: Firebird ODBC ou driver nativo.
# NUNCA executar INSERT/UPDATE/DELETE neste banco.
# ============================================================
SIA_HOST=192.168.1.100
SIA_PORT=3050
SIA_DATABASE=/dados/sia/empresa.fdb
SIA_USER=sysdba
SIA_PASSWORD=troque-por-senha-sia
SIA_CODEMP=1

# DSN ODBC alternativo (se configurado no sistema)
# SIA_DSN=SIA_ODBC_DSN

# ============================================================
# METABASE
# ============================================================
MB_DB_TYPE=postgres
MB_DB_HOST=db
MB_DB_PORT=5432
MB_DB_DBNAME=metabase
MB_DB_USER=metabase_user
MB_DB_PASS=troque-por-senha-metabase

# ============================================================
# API
# ============================================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2

# ============================================================
# ETL
# ============================================================
ETL_BATCH_SIZE=1000
ETL_LOG_LEVEL=INFO
# Threshold de variação para exigir justificativa (em %)
VARIACAO_THRESHOLD_PCT=10
